# Dependencies
node_modules/

# Environment / secrets
.env
.env.local
.env.*.local

# Build output
dist/
build/

# Logs
*.log
logs/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Test coverage
coverage/

# Editor / IDE
.vscode/
.idea/

# OS junk
.DS_Store
Thumbs.db

# Stray temp scripts (ad-hoc verification scripts during development)
*.tmp.js

# Docs (coursework write-ups, pentest evidence, etc.) kept local, not committed
docs/

# User-uploaded equipment photos — the directory itself is tracked (.gitkeep), contents aren't
backend/public/equipmentImages/*
!backend/public/equipmentImages/.gitkeep
