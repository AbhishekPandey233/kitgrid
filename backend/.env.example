PORT=5000
NODE_ENV=development

# MongoDB / Redis
DB_URI=mongodb://mongo:27017/kitgrid
REDIS_URL=redis://redis:6379

# Auth
JWT_SECRET=changeme
JWT_REFRESH_SECRET=changeme

# Google OAuth (free — no billing needed for basic sign-in)
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=

# AES-256-GCM key used to encrypt MFA secrets at rest
MFA_ENCRYPTION_KEY=changeme

# hCaptcha / reCAPTCHA v2 (free tier)
CAPTCHA_SECRET=

# Ethereal Email — free, no-signup disposable test SMTP (not a real inbox)
ETHEREAL_EMAIL=
ETHEREAL_PASSWORD=

# CORS
FRONTEND_ORIGIN=http://localhost:5173
