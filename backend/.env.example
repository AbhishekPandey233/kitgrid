PORT=5000
NODE_ENV=development

# MongoDB / Redis
# Use mongodb://mongo:27017/kitgrid when running via docker-compose (container-to-container).
# Use mongodb://localhost:27017/kitgrid when running the backend natively against a local
# or port-mapped Mongo — the /kitgrid database name keeps this fully isolated from any other
# local databases on the same Mongo server (e.g. Drivana).
DB_URI=mongodb://localhost:27017/kitgrid
REDIS_URL=redis://localhost:6379

# Auth
JWT_SECRET=changeme
JWT_REFRESH_SECRET=changeme

# Google OAuth 
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=

# AES-256-GCM key used to encrypt MFA secrets at rest
MFA_ENCRYPTION_KEY=changeme

# hCaptcha / reCAPTCHA v2 (free tier)
CAPTCHA_SECRET=

# Ethereal Email 
ETHEREAL_PASSWORD=

# CORS / OAuth redirect base
FRONTEND_ORIGIN=http://localhost:5173
BACKEND_ORIGIN=http://localhost:5000

# Comma-separated IPs that bypass IP-based login lockout (e.g. trusted office/CI IPs)
ALLOWED_IPS=

# Reject token refresh if the device fingerprint (User-Agent + client device id) doesn't
# match what was recorded at login. Off by default — can be too strict for some clients.
DEVICE_BINDING_ENABLED=false
