PORT=5000
NODE_ENV=development

# MongoDB / Redis
# Use mongodb://mongo:27017/kitgrid?replicaSet=rs0 when running via docker-compose
# (container-to-container). Use mongodb://localhost:27017/kitgrid?replicaSet=rs0 when
# running the backend natively against a local or port-mapped Mongo — the /kitgrid database
# name keeps this fully isolated from any other local databases on the same Mongo server
# (e.g. Drivana). The replicaSet param is required: booking creation (Phase 18) uses a
# multi-document transaction, which needs Mongo running as a replica set (even a
# single-node one — see docker-compose.yml) rather than a plain standalone mongod.
DB_URI=mongodb://localhost:27017/kitgrid?replicaSet=rs0
REDIS_URL=redis://localhost:6379

# Auth
JWT_SECRET=changeme
JWT_REFRESH_SECRET=changeme
# Falls back to JWT_SECRET if unset, but a dedicated secret keeps the blast radius of a
# leak contained to CSRF tokens rather than access tokens too.
CSRF_SECRET=changeme

# Google OAuth 
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=

# AES-256-GCM key used to encrypt MFA secrets at rest
MFA_ENCRYPTION_KEY=changeme

# hCaptcha / reCAPTCHA v2 (free tier)
CAPTCHA_SECRET=

# Ethereal Email — free, no-signup disposable test SMTP. Leave both blank to have a fresh
# disposable test account created automatically at first use (nodemailer.createTestAccount());
# set both to pin a specific one instead.
ETHEREAL_EMAIL=
ETHEREAL_PASSWORD=

# Days a password stays valid before login rejects it as expired and requires a reset.
PASSWORD_EXPIRY_DAYS=90

# CORS / OAuth redirect base
FRONTEND_ORIGIN=https://localhost:5173
BACKEND_ORIGIN=https://localhost:5000

# Local dev TLS cert/key (optional — falls back to plain HTTP if unset). Generate with:
#   mkcert -cert-file certs/dev-cert.pem -key-file certs/dev-key.pem localhost 127.0.0.1 ::1
# certs/ is gitignored; each dev generates their own.
TLS_CERT_PATH=
TLS_KEY_PATH=

# Comma-separated IPs that bypass IP-based login lockout (e.g. trusted office/CI IPs)
ALLOWED_IPS=

# Reject token refresh if the device fingerprint (User-Agent + client device id) doesn't
# match what was recorded at login. Off by default — can be too strict for some clients.
DEVICE_BINDING_ENABLED=false

# WebAuthn (passkey) "Relying Party" identity. rpID must exactly equal the domain the
# frontend is served from (no scheme/port) — leave blank to derive it from FRONTEND_ORIGIN's
# hostname, which is correct for local dev. Set explicitly for a real deployment.
WEBAUTHN_RP_ID=
WEBAUTHN_RP_NAME=KitGrid
